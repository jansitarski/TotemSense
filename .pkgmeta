package-as: CCPlates

enable-nolib-creation: no

manual-changelog:
  filename: CHANGELOG.md
  markup-type: markdown

ignore:
  - README.md
  - CONTRIBUTING.md
  - PROJECT_STRUCTURE.md
  - .git
  - .github
  - database
  - plater/__pycache__
  - plater/data
  - plater/generate_import_string.py
  - plater/IMPORT_STRING.md
  - plater/database_generated.lua
  - plater/config.lua
